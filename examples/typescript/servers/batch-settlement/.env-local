EVM_ADDRESS=0x...
FACILITATOR_URL=http://localhost:4022

# Recommended: self-managed receiver authorizer key. Channels survive facilitator changes.
# Omit to delegate to the facilitator's advertised authorizer (channels are then bound to
# that facilitator until drained).
EVM_RECEIVER_AUTHORIZER_PRIVATE_KEY=

STORAGE_DIR=
DEFERRED_WITHDRAW_DELAY_SECONDS=900
