# x402 Error Handling Example Configuration

# EVM (Ethereum/Base) Private Key
# Required for EVM-based payments (Base, Ethereum, Polygon, etc.)
EVM_PRIVATE_KEY=0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef

# Solana Private Key (base58 encoded)
# Required for Solana-based payments
SVM_PRIVATE_KEY=5Kb8kLf9CJYs4fJJkGXTEWNS1ZdJXWQTxZXbNjXQTxZXbNjXQTxZXbNjXQTxZXbNjXQTxZXbNjXQ

# Resource Server Configuration
# URL of the x402-protected server to test against
RESOURCE_SERVER_URL=http://localhost:4021

# Specific endpoint path to test (optional, defaults to /weather)
ENDPOINT_PATH=/weather

# Monitoring Configuration (optional)
# Webhook URL for alert notifications (Slack, Discord, etc.)
WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Environment (for structured logging)
NODE_ENV=development

# Optional: Custom facilitator URLs
# EVM_FACILITATOR_URL=https://facilitator.example.com
# SVM_FACILITATOR_URL=https://facilitator.example.com