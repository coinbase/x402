# Polygon Mainnet x402 Client Configuration

# Your private key (without 0x prefix)
# SECURITY: Never commit real private keys! Use environment variables in production.
PRIVATE_KEY=your_private_key_here

# Polygon mainnet RPC URL (choose one or rotate through multiple)
RPC_URL=https://polygon.llamarpc.com

# Alternative RPC endpoints:
# RPC_URL=https://polygon-mainnet.public.blastapi.io
# RPC_URL=https://rpc.ankr.com/polygon  
# RPC_URL=https://polygon.blockpi.network/v1/rpc/public
# RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR-API-KEY

# Target server to test payments against
TARGET_URL=https://api.example.com/paid-endpoint

# Payment amount in USDC (e.g., 0.001 = $0.001)
PAYMENT_AMOUNT=0.001

# Facilitator URL (default: Coinbase facilitator)
FACILITATOR_URL=https://x402.org/facilitator