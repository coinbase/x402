{
  "name": "fetch",
  "type": "client",
  "language": "typescript",
  "protocolFamilies": [
    "evm",
    "svm",
    "avm",
    "aptos",
    "hedera",
    "stellar"
  ],
  "x402Versions": [
    1,
    2
  ],
  "evm": {
    "transferMethods": [
      "eip3009",
      "permit2",
      "upto"
    ]
  },
  "extensions": [
    "eip2612GasSponsoring",
    "erc20ApprovalGasSponsoring"
  ],
  "environment": {
    "required": [
      "EVM_PRIVATE_KEY",
      "SVM_PRIVATE_KEY",
      "RESOURCE_SERVER_URL",
      "ENDPOINT_PATH"
    ],
    "optional": [
      "AVM_PRIVATE_KEY",
      "APTOS_PRIVATE_KEY",
      "HEDERA_ACCOUNT_ID",
      "HEDERA_PRIVATE_KEY",
      "HEDERA_NETWORK",
      "HEDERA_NODE_URL",
      "STELLAR_PRIVATE_KEY"
    ]
  }
}
