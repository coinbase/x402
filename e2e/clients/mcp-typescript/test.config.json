{
  "name": "mcp-typescript",
  "type": "client",
  "transport": "mcp",
  "language": "typescript",
  "protocolFamilies": [
    "evm"
  ],
  "x402Versions": [
    2
  ],
  "schemes": [
    "exact",
    "batch-settlement"
  ],
  "evm": {
    "assetTransferMethods": [
      "eip3009",
      "permit2"
    ]
  },
  "environment": {
    "required": [
      "EVM_PRIVATE_KEY",
      "RESOURCE_SERVER_URL",
      "ENDPOINT_PATH"
    ],
    "optional": [
      "CHANNEL_SALT",
      "BATCH_SETTLEMENT_PHASE",
      "EVM_VOUCHER_SIGNER_PRIVATE_KEY"
    ]
  }
}
