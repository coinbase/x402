# Hedera live integration test environment (ECDSA keys only)
# Used by: pnpm test:integration (via vitest.integration.config.ts)
#
# IMPORTANT:
# - Keys below must be ECDSA private keys.
# - Accepted format for this suite: 0x-prefixed raw ECDSA key (or DER-encoded key string).
# - These values are loaded only when running integration tests.

HEDERA_CLIENT_ACCOUNT_ID= # e.g. 0.0.1234567
HEDERA_CLIENT_PRIVATE_KEY= # e.g. 0xabc123...

HEDERA_FACILITATOR_ACCOUNT_ID= # e.g. 0.0.2345678
HEDERA_FACILITATOR_PRIVATE_KEY= # e.g. 0xdef456...

HEDERA_RESOURCE_SERVER_ACCOUNT_ID= # e.g. 0.0.3456789
